# --- DATABASE (MongoDB) ---
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=your_mongodb_connection_string_here
MONGODB_DB=learnez_ai
MONGODB_RAW_DB=elearning_raw
MONGODB_AI_DB=learnez_ai

# --- AUTH & STORAGE (Supabase) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key
SUPABASE_MATERIALS_BUCKET=module-materials

# --- SECURITY ---
JWT_SECRET=your_super_secret_jwt_key_here

# --- MEDIA (Cloudinary) ---
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- APP SETTINGS ---
STUDENT_FILE_MAX_MB=5
STUDENT_STORAGE_QUOTA_MB=10

# --- AI / LLM (Primary: OpenRouter) ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODELS=qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_TITLE=Learnez

# --- AI / LLM (Fallback: Gemini) ---
LLM_FALLBACK_PROVIDER=gemini
GEMINI_API_KEY=your_google_gemini_api_key_here
LLM_FALLBACK_MODEL=gemini-2.5-flash-lite